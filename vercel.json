{
  "buildCommand": "",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/flights.py": {
      "maxDuration": 180
    },
    "api/summary.py": {
      "maxDuration": 20
    },
    "api/multicity.py": {
      "maxDuration": 60
    },
    "api/hotels.py": {
      "maxDuration": 30
    },
    "api/points.py": {
      "maxDuration": 20
    },
    "api/parse_screenshot.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/((?!api/).*)", "destination": "/public/$1" }
  ]
}
